{
  "version": "2.0.0",
  "configurations": [
    {
      "name": "VuePress 开发服务器",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}",
      "serverReadyAction": {
        "pattern": "on http://localhost:([0-9]+)",
        "uriFormat": "http://localhost:%s",
        "action": "openExternally"
      }
    },
    {
      "name": "本地沙箱服务",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run server",
      "cwd": "${workspaceFolder}",
      "serverReadyAction": {
        "pattern": "API: http://localhost:([0-9]+)",
        "uriFormat": "http://localhost:%s/api/health",
        "action": "openExternally"
      }
    },
    {
      "name": "完整本地模式",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run local",
      "cwd": "${workspaceFolder}",
      "serverReadyAction": {
        "pattern": "on http://localhost:([0-9]+)",
        "uriFormat": "http://localhost:%s",
        "action": "openExternally"
      }
    },
    {
      "name": "构建生产版本",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run build",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "构建 Docker 沙箱镜像",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run build:sandbox",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "停止已运行服务",
      "type": "node-terminal",
      "request": "launch",
      "command": "bash -c 'pkill -f \"node.*vuepress\" 2>/dev/null; pkill -f \"node.*local-server\" 2>/dev/null; pkill -f \"node.*vite\" 2>/dev/null; lsof -ti:8080 | xargs -r kill -9 2>/dev/null; lsof -ti:3001 | xargs -r kill -9 2>/dev/null; echo \"已停止所有服务并释放端口\"'",
      "cwd": "${workspaceFolder}"
    }
  ],
  "compounds": [
    {
      "name": "调试：前端 + 后端",
      "configurations": ["VuePress 开发服务器", "本地沙箱服务"],
      "stopAll": true
    }
  ]
}