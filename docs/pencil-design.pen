                            }
                          ]
                        },
                        {
                          "type": "text",
                          "id": "G6FLs",
                          "name": "metaDivider",
                          "fill": "#71717A",
                          "content": "·",
                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "5lOH0",
                          "name": "metaDate",
                          "fill": "#71717A",
                          "content": "2024年1月15日",
                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "text",
                  "id": "IyXpj",
                  "name": "articleIntro",
                  "fill": "#18181B",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "当我们谈论机器学习时，往往聚焦于复杂的算法模型和令人惊叹的应用场景，譬如 AlphaGo 击败围棋世界冠军、ChatGPT 生成流畅自然的对话。深入本质，支撑这一切的底层语言正是线性代数。",
                  "lineHeight": 1.6,
                  "fontFamily": "Inter",
                  "fontSize": 16,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "5m5ad",
                  "name": "sectionTitle1",
                  "fill": "#18181B",
                  "content": "空间中的箭头 - 向量",
                  "fontFamily": "Inter",
                  "fontSize": 24,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "X3tZo",
                  "name": "sectionText1",
                  "fill": "#18181B",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "线性代数的一个美妙之处在于它的几何直观。在二维平面上，向量可以理解为一个从原点出发的有向箭头。向量 (3, 2) 表示从原点 (0, 0) 指向点 (3, 2) 的箭头。",
                  "lineHeight": 1.6,
                  "fontFamily": "Inter",
                  "fontSize": 16,
                  "fontWeight": "normal"
                },
                {
