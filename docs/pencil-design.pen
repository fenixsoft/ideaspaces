                      "children": [
                        {
                          "type": "frame",
                          "id": "P9BOC",
                          "name": "metaTags",
                          "gap": 8,
                          "children": [
                            {
                              "type": "text",
                              "id": "dfBMA",
                              "name": "tag1",
                              "fill": "#2563EB",
                              "content": "线性代数",
                              "fontFamily": "Inter",
                              "fontSize": 12,
