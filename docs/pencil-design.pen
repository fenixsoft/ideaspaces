                          "fontSize": 14,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "xuxsO",
                          "name": "codeLine4",
                          "fill": "#ABB2BF",
                          "content": "    def wrapper(*args, **kwargs):",
                          "fontFamily": "Fira Code",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "BIXzF",
                          "name": "codeLine5",
                          "fill": "#ABB2BF",
                          "content": "        start = time.time()",
                          "fontFamily": "Fira Code",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "KY9kS",
                          "name": "codeLine6",
                          "fill": "#ABB2BF",
                          "content": "        result = func(*args, **kwargs)",
                          "fontFamily": "Fira Code",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "C4oqf",
                          "name": "codeLine7",
                          "fill": "#98C379",
                          "content": "        print(f'Time: {time.time() - start:.2f}s')",
