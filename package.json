{
  "name": "dmla",
  "version": "1.0.0",
  "description": "Design Machine Learning Applications - 设计机器学习应用系统",
  "type": "module",
  "scripts": {
    "dev": "vuepress dev docs",
    "build": "vuepress build docs",
    "local": "concurrently \"npm run dev\" \"npm run server\"",
    "server": "cd local-server && npm start",
    "extract:shared": "node scripts/extract-shared-modules.js",
    "build:sandbox": "npm run extract:shared && docker build -t dmla-sandbox:gpu . -f local-server/Dockerfile.sandbox",
    "build:sandbox:cpu": "npm run extract:shared && docker build -t dmla-sandbox:latest . -f local-server/Dockerfile.sandbox.cpu",
    "build:sandbox:all": "npm run build:sandbox && npm run build:sandbox:cpu",
    "cdn:refresh": "node scripts/cdn-refresh.js"
  },
  "keywords": [
    "knowledge-base",
    "vuepress",
    "education",
    "markdown"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@vuepress/bundler-vite": "2.0.0-rc.19",
    "@vuepress/plugin-git": "2.0.0-rc.66",
    "@vuepress/plugin-prismjs": "2.0.0-rc.66",
    "@vuepress/plugin-register-components": "2.0.0-rc.66",
    "@vuepress/theme-default": "2.0.0-rc.66",
    "concurrently": "^9.1.2",
    "github-buttons": "^2.13.0",
    "markdown-it": "^14.1.0",
    "sass-embedded": "^1.86.0",
    "slimsearch": "^2.2.2",
    "tencentcloud-sdk-nodejs-cdn": "^4.1.200",
    "vuepress": "2.0.0-rc.19",
    "vuepress-plugin-search-pro": "^2.0.0-rc.59"
  },
  "dependencies": {
    "katex": "^0.16.42",
    "mermaid": "^11.13.0",
    "vue": "^3.5.13"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "vuepress": "2.0.0-rc.19",
    "@vuepress/helper": "2.0.0-rc.66",
    "@vueuse/core": "^12.0.0"
  }
}
